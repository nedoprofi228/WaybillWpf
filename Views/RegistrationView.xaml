<Window x:Class="WaybillWpf.Views.RegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModels1="clr-namespace:WaybillWpf.ViewModels"
        mc:Ignorable="d"
        Title="Регистрация" 
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height" Width="400"
        ResizeMode="NoResize"
        Background="#F9FAFB" FontFamily="Segoe UI"
        d:DataContext="{d:DesignInstance viewModels1:RegistrationViewModel, IsDesignTimeCreatable=False}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Заголовок -->
            <RowDefinition Height="Auto"/> <!-- Поля -->
            <RowDefinition Height="Auto"/> <!-- Ошибка -->
            <RowDefinition Height="Auto"/> <!-- Кнопки -->
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Новый пользователь" FontSize="22" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="ФИО" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

            <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                     Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <PasswordBox Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"
                         Height="35" VerticalContentAlignment="Center" Padding="5" Margin="0,0,0,15" BorderBrush="#D1D5DB"/>

            <TextBlock Text="Повторите пароль" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <PasswordBox Name="ConfirmPasswordBox" PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                         Height="35" VerticalContentAlignment="Center" Padding="5" BorderBrush="#D1D5DB"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#DC2626" Margin="0,15"
                   TextWrapping="Wrap" TextAlignment="Center"/>

        <StackPanel Grid.Row="3" Orientation="Vertical">
            <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" IsDefault="True"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    Height="40" Cursor="Hand" Margin="0,0,0,10">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>
            
            <Button Content="Регистрация как водитель" Command="{Binding ToAuthDriverCommand}" 
                    Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Height="35" Margin="0,0,0,10">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>

            <Button Content="Уже есть аккаунт? Войти" Command="{Binding ToLoginCommand}" 
                    Background="Transparent" Foreground="#3B82F6" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>