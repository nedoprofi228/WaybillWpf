<Window x:Class="WaybillWpf.Views.Admin.AdminMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WaybillWpf.ViewModels.Admin"
        xmlns:views="clr-namespace:WaybillWpf.Views.Admin"
        xmlns:views1="clr-namespace:WaybillWpf.Views"
        xmlns:global="clr-namespace:"
        mc:Ignorable="d"
        Title="Панель Администратора" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"> <!-- Светлый фон всего окна -->

    <!-- Привязка DataContext (лучше делать через DI, но для дизайнера можно оставить) -->
    <d:Window.DataContext>
        <vm:AdminMainViewModel/>
    </d:Window.DataContext>

    <Window.Resources>
        <!-- ШАБЛОНЫ ДЛЯ ПЕРЕКЛЮЧЕНИЯ VIEW -->
        <DataTemplate DataType="{x:Type vm:AdminCarsViewModel}">
            <views:AdminCarsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminDriversViewModel}">
            <views1:AdminDriversView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type global:AdminStatisticsViewModel}">
            <views:AdminStatisticsView/>
        </DataTemplate>

        <!-- СТИЛЬ ДЛЯ КНОПОК МЕНЮ -->
        <Style TargetType="Button" x:Key="MenuButtonStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/> <!-- Светло-серый текст -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#374151"/> <!-- Темно-серый фон при наведении -->
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛЬ ДЛЯ КНОПКИ ВЫХОДА -->
        <Style TargetType="Button" x:Key="LogoutButtonStyle" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Foreground" Value="#F87171"/> <!-- Красный текст -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F1D1D"/> <!-- Темно-красный фон -->
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/> <!-- Меню пошире -->
            <ColumnDefinition Width="*"/>   <!-- Контент -->
        </Grid.ColumnDefinitions>

        <!-- === ЛЕВОЕ МЕНЮ (SIDEBAR) === -->
        <Border Grid.Column="0" Background="#1F2937"> <!-- Темный фон (Tailwind Gray-800) -->
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Лого -->
                    <RowDefinition Height="*"/>    <!-- Меню -->
                    <RowDefinition Height="Auto"/> <!-- Футер -->
                </Grid.RowDefinitions>

                <!-- ЛОГОТИП / ЗАГОЛОВОК -->
                <StackPanel Grid.Row="0" Margin="0,10,0,30">
                    <Border Background="#3B82F6" Width="40" Height="40" CornerRadius="8" HorizontalAlignment="Left" Margin="10,0,0,10">
                        <TextBlock Text="A" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="ПАНЕЛЬ" Foreground="#6B7280" FontSize="12" FontWeight="Bold" Margin="10,0,0,0" />
                    <TextBlock Text="АДМИНИСТРАТОРА" Foreground="White" FontSize="18" FontWeight="Bold" Margin="10,-2,0,0"/>
                </StackPanel>

                <!-- КНОПКИ МЕНЮ -->
                <StackPanel Grid.Row="1">
                    <Button Content="📊 Статистика" Command="{Binding ShowStatsCommand}" Style="{StaticResource MenuButtonStyle}" Margin="0,2"/>
                    <Button Content="🚗 Автопарк" Command="{Binding ShowCarsCommand}" Style="{StaticResource MenuButtonStyle}" Margin="0,2"/>
                    <Button Content="👨‍✈️ Водители" Command="{Binding ShowDriversCommand}" Style="{StaticResource MenuButtonStyle}" Margin="0,2"/>
                </StackPanel>

                <!-- НИЗ МЕНЮ (ВЫХОД) -->
                <StackPanel Grid.Row="2">
                    <Rectangle Height="1" Fill="#374151" Margin="5,10,5,15"/>
                    <Button Content="🚪 Выйти" Command="{Binding LogoutCommand}" Style="{StaticResource LogoutButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- === ПРАВАЯ ЧАСТЬ (КОНТЕНТ) === -->
        <Grid Grid.Column="1">
            <!-- Фон с легким градиентом или просто цветом -->
            <Border Background="#F3F4F6"/>

            <!-- Контейнер для сменяемых View -->
            <Border Margin="20" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.08"/>
                </Border.Effect>
                
                <!-- Сюда подгружаются UserControl'ы -->
                <ContentControl Content="{Binding CurrentView}" 
                                Margin="0" 
                                ClipToBounds="True"/> <!-- Обрезаем контент по скруглению Border -->
            </Border>
        </Grid>
    </Grid>
</Window>