<Window x:Class="WaybillWpf.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Вход в систему" 
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height" Width="400"
        ResizeMode="NoResize"
        Background="#F9FAFB" FontFamily="Segoe UI">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Заголовок -->
            <RowDefinition Height="Auto"/> <!-- Поля -->
            <RowDefinition Height="Auto"/> <!-- Ошибка -->
            <RowDefinition Height="Auto"/> <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
            <TextBlock Text="Авторизация" FontSize="24" FontWeight="Bold" Foreground="#111827" HorizontalAlignment="Center"/>
            <TextBlock Text="Введите данные для входа" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Поля ввода -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Логин" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                     Height="40" VerticalContentAlignment="Center" Padding="10,0"
                     BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" FontSize="13" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <PasswordBox Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged"
                         Height="40" VerticalContentAlignment="Center" Padding="10,0"
                         BorderBrush="#D1D5DB" BorderThickness="1"/>
        </StackPanel>

        <!-- Ошибка -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" 
                   Foreground="#DC2626" FontSize="13" TextWrapping="Wrap" 
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Margin="0,15" MinHeight="20"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Vertical">
            <Button Content="Войти" Command="{Binding LoginCommand}" IsDefault="True"
                    Background="#3B82F6" Foreground="White" FontWeight="Bold" BorderThickness="0"
                    Height="40" Cursor="Hand" Margin="0,0,0,10">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
            
            <Button Content="Нет аккаунта? Регистрация" Command="{Binding OpenRegistrationCommand}" 
                    Background="Transparent" Foreground="#3B82F6" BorderThickness="0"
                    Cursor="Hand" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>