<UserControl x:Class="WaybillWpf.Views.Admin.AdminStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:WaybillWpf.ViewModels.Admin"
             xmlns:global="clr-namespace:"
             xmlns:wpf="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             d:DataContext="{d:DesignInstance Type=global:AdminStatisticsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="#F3F4F6" FontFamily="Segoe UI">

    <UserControl.Resources>
        <!-- СТИЛЬ ДЛЯ KPI КАРТОЧЕК -->
        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Direction="270" Color="#E5E7EB" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ КНОПКИ ФИЛЬТРА -->
        <Style TargetType="Button" x:Key="FilterButtonStyle">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ ВКЛАДОК (TabItem) -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"  Margin="0,0,10,0" Padding="15,8" CornerRadius="6" Background="Transparent" Cursor="Hand">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E5E7EB"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <!-- Переопределение при наведении если выбран -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ DATAGRID -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F3F4F6"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Фильтр -->
            <RowDefinition Height="*"/>    <!-- Табы -->
        </Grid.RowDefinitions>

        <!-- 1. ПАНЕЛЬ ФИЛЬТРОВ -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Аналитика за период" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,20,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="с" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,5,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="120" VerticalContentAlignment="Center"/>
                    
                    <TextBlock Text="по" VerticalAlignment="Center" Foreground="Gray" Margin="15,0,5,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="120" VerticalContentAlignment="Center"/>

                    <Button Content="Обновить" Command="{Binding LoadStatsCommand}" Style="{StaticResource FilterButtonStyle}" Width="100" Margin="20,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. ВКЛАДКИ ОТЧЕТОВ -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            
            <!-- === ВКЛАДКА 1: ДАШБОРД === -->
            <TabItem Header="Дашборд">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- KPI КАРТОЧКИ -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Карточка 1: Листы -->
                        <Border Grid.Column="0" Style="{StaticResource KpiCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#DBEAFE" Width="32" Height="32" CornerRadius="8">
                                        <TextBlock Text="📄" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Всего листов" Foreground="#6B7280" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding Dashboard.TotalWaybills}" FontSize="32" FontWeight="Bold" Foreground="#111827" Margin="0,10,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Карточка 2: Пробег -->
                        <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#D1FAE5" Width="32" Height="32" CornerRadius="8">
                                        <TextBlock Text="🚗" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Суммарный пробег" Foreground="#6B7280" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding Dashboard.TotalMileage, StringFormat=F1}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock Text="км" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="5,0,0,5"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Карточка 3: Топливо -->
                        <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#FEF3C7" Width="32" Height="32" CornerRadius="8">
                                        <TextBlock Text="⛽" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Расход топлива" Foreground="#6B7280" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding Dashboard.TotalFuelConsumed, StringFormat=F1}" FontSize="32" FontWeight="Bold" Foreground="#111827"/>
                                    <TextBlock Text="л" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Bottom" Margin="5,0,0,5"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Пустое место или график в будущем -->
                    <Border Grid.Row="1" Margin="10" Background="White" CornerRadius="10" Padding="20">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
                        </Border.Effect>
    
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Заголовок графика -->
                            <TextBlock Text="📊 Расход топлива: План / Факт" 
                                       FontSize="16" FontWeight="Bold" Foreground="#374151" 
                                       HorizontalAlignment="Left" Margin="0,0,0,15"/>

                            <!-- Сам График -->
                            <wpf:CartesianChart Grid.Row="1" Series="{Binding FuelChartSeries}" LegendLocation="Right">
            
                                <!-- Ось X (Машины) -->
                                <wpf:CartesianChart.AxisX>
                                    <wpf:Axis Labels="{Binding ChartLabels}">
                                        <wpf:Axis.Separator>
                                            <wpf:Separator Step="1" StrokeThickness="0"/> <!-- Убираем вертикальные линии -->
                                        </wpf:Axis.Separator>
                                    </wpf:Axis>
                                </wpf:CartesianChart.AxisX>

                                <!-- Ось Y (Литры) -->
                                <wpf:CartesianChart.AxisY>
                                    <wpf:Axis LabelFormatter="{Binding ChartFormatter}" MinValue="0">
                                        <wpf:Axis.Separator>
                                            <wpf:Separator Stroke="#F3F4F6"/> <!-- Легкие линии сетки -->
                                        </wpf:Axis.Separator>
                                    </wpf:Axis>
                                </wpf:CartesianChart.AxisY>
            
                                <!-- Тултип (Всплывашка при наведении) -->
                                <wpf:CartesianChart.DataTooltip>
                                    <wpf:DefaultTooltip SelectionMode="SharedYValues" Background="White" BorderThickness="1" BorderBrush="#E5E7EB"/>
                                </wpf:CartesianChart.DataTooltip>
            
                            </wpf:CartesianChart>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- === ВКЛАДКА 2: ТОПЛИВО === -->
            <TabItem Header="Расход топлива">
                <Border Background="White" CornerRadius="10" Margin="0,15,0,0" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
                    </Border.Effect>
                    <DataGrid ItemsSource="{Binding FuelReport}" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер автомобиля" Binding="{Binding CarNumber}" Width="*"/>
                            <DataGridTextColumn Header="Пробег (км)" Binding="{Binding Distance, StringFormat=F1}" Width="120"/>
                            
                            <DataGridTextColumn Header="Факт (л)" Binding="{Binding FactFuel, StringFormat=F1}" Width="120" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Норма (л)" Binding="{Binding NormFuel, StringFormat=F1}" Width="120"/>
                            
                            <DataGridTextColumn Header="Разница" Binding="{Binding Difference, StringFormat=F1}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <!-- Простая логика: если есть текст, красим (сложную логику +/- лучше через ValueConverter) -->
                                        <Setter Property="Foreground" Value="#DC2626"/> 
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- === ВКЛАДКА 3: ПО МАШИНАМ === -->
            <TabItem Header="По машинам">
                <Border Background="White" CornerRadius="10" Margin="0,15,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
                    </Border.Effect>
                    <DataGrid ItemsSource="{Binding MileageByCarReport}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер машины" Binding="{Binding EntityName}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во поездок" Binding="{Binding TotalTrips}" Width="150"/>
                            <DataGridTextColumn Header="Суммарный пробег" Binding="{Binding TotalMileage, StringFormat=F1}" Width="180" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            
            <!-- === ВКЛАДКА 4: ПО ВОДИТЕЛЯМ === -->
            <TabItem Header="По водителям">
                <Border Background="White" CornerRadius="10" Margin="0,15,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
                    </Border.Effect>
                    <DataGrid ItemsSource="{Binding MileageByDriverReport}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Водитель" Binding="{Binding EntityName}" Width="*"/>
                            <DataGridTextColumn Header="Кол-во поездок" Binding="{Binding TotalTrips}" Width="150"/>
                            <DataGridTextColumn Header="Суммарный пробег" Binding="{Binding TotalMileage, StringFormat=F1}" Width="180" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>