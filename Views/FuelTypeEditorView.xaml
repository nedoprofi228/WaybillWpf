<?xml version="1.0" encoding="UTF-8" ?>
<Window x:Class="WaybillWpf.Views.Admin.FuelTypeEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:WaybillWpf.ViewModels.Admin"
        d:DataContext="{d:DesignInstance Type=viewmodels:FuelTypeEditorViewModel}"
        mc:Ignorable="d"
        Title="Вид топлива"
        Height="300"
        Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F4F6"
        FontFamily="Segoe UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <!-- Растяжка -->
            <RowDefinition Height="Auto" />
            <!-- Кнопки -->
        </Grid.RowDefinitions>
        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Данные вида топлива"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Margin="0,0,0,20" />
        <!-- Название -->
        <TextBlock Grid.Row="1"
                   Text="Название"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#4B5563"
                   Margin="0,0,0,5" />
        <TextBox Grid.Row="2"
                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 Height="35"
                 VerticalContentAlignment="Center"
                 Padding="5"
                 BorderBrush="#D1D5DB"
                 BorderThickness="1"
                 Margin="0,0,0,15" />
        <!-- Цена -->
        <TextBlock Grid.Row="3"
                   Text="Стоимость за литр"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#4B5563"
                   Margin="0,0,0,5" />
        <TextBox Grid.Row="4"
                 Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}"
                 Height="35"
                 VerticalContentAlignment="Center"
                 Padding="5"
                 BorderBrush="#D1D5DB"
                 BorderThickness="1"
                 Margin="0,0,0,15" />
        <!-- Кнопки -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0"
                    VerticalAlignment="Bottom">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Background="#3B82F6"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Padding="20,8"
                    Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Отмена"
                    IsCancel="True"
                    Background="White"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Padding="15,8">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius"
                                Value="5" />
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>