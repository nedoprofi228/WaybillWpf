<Window x:Class="WaybillWpf.Views.ReasonEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WaybillWpf.Views"
        mc:Ignorable="d"
Title="Отклонение заявки"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        SizeToContent="Height" Width="450"
        Background="#FFFFFF" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Заголовок -->
                <RowDefinition Height="Auto"/> <!-- Поле ввода -->
                <RowDefinition Height="Auto"/> <!-- Ошибка -->
                <RowDefinition Height="Auto"/> <!-- Кнопки -->
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="Причина отклонения" FontSize="20" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

            <!-- Основное содержимое -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="Укажите причину" FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                
                <!-- Многострочный TextBox -->
                <TextBox Text="{Binding RejectionReason, UpdateSourceTrigger=PropertyChanged}" 
                         IsEnabled="{Binding !IsLoading}"
                         Height="120" 
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" 
                         Padding="10"
                         BorderBrush="#D1D5DB"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Блок ошибки -->
            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="#DC2626" 
                       Margin="0,15" TextWrapping="Wrap" MinHeight="20"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Command="{Binding CancelCommand}" IsCancel="True"
                        Background="White" BorderBrush="#D1D5DB" BorderThickness="1"
                        Padding="20,10" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>

                <!-- Кнопка действия (Красная для отклонения) -->
                <Button Content="Отклонить" Command="{Binding RejectCommand}" IsDefault="True"
                        Background="#DC2626" Foreground="White" FontWeight="Bold" BorderThickness="0"
                        Padding="20,10">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Загрузка (Overlay) -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⌛" FontSize="30" HorizontalAlignment="Center"/>
                <TextBlock Text="Обработка..." FontWeight="SemiBold" Foreground="#4B5563" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
