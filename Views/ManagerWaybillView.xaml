<Window x:Class="WaybillWpf.Views.ManagerWaybillView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:converters="clr-namespace:WaybillWpf.Converters"
        xmlns:viewModels="clr-namespace:WaybillWpf.ViewModels"
        mc:Ignorable="d" 
        d:DataContext="{d:DesignInstance viewModels:ManagerWaybillViewModel, IsDesignTimeCreatable=False}"
        d:DesignHeight="700" d:DesignWidth="1200"
        Title="Диспетчерская" WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"> <!-- Светло-серый фон -->
    
    <Window.Resources>
        <converters:CustomBooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Стили кнопок (как у водителя, для единообразия) -->
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#2563EB"/> <!-- Синий -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="15"/> <!-- Отступ -->
            <ColumnDefinition Width="*"/> 
        </Grid.ColumnDefinitions>

        <!-- === ЛЕВАЯ КОЛОНКА (СПИСОК) === -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
            </Border.Effect>
            
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>  
                    <RowDefinition Height="Auto"/> 
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Журнал путевых листов" FontSize="18" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Все документы" FontSize="12" Foreground="#6B7280"/>
                </StackPanel>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding WaybillsList}" 
                          SelectedItem="{Binding SelectedWaybill}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          SelectionMode="Single"
                          BorderThickness="0" GridLinesVisibility="Horizontal" RowHeight="35" >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="40" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding AtCreated, StringFormat=dd.MM, Mode=OneWay}" Width="50"/>
                        <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.Model}" Width="*"/>
                        
                        <!-- Статус (Бейдж) -->
                        <DataGridTemplateColumn Header="Статус" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="6,1" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E5E7EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Draft">
                                                        <Setter Property="Background" Value="#F3F4F6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Issued">
                                                        <Setter Property="Background" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="InProgress">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Accepting">
                                                        <Setter Property="Background" Value="#FEF9C3"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Completed">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding WaybillStatus}"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                    <Setter Property="Height" Value="25"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Draft">
                                                            <Setter Property="Foreground" Value="Gray"/>
                                                            <Setter Property="Text" Value="Черновик"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Issued">
                                                            <Setter Property="Foreground" Value="Blue"/>
                                                            <Setter Property="Text" Value="Выдан"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="InProgress">
                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                            <Setter Property="Text" Value="В пути"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Accepting">
                                                            <Setter Property="Foreground" Value="#CA8A04"/>
                                                            <Setter Property="Text" Value="Сдача"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Completed">
                                                            <Setter Property="Foreground" Value="Green"/>
                                                            <Setter Property="Text" Value="Завершен"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- КНОПКИ УПРАВЛЕНИЯ СПИСКОМ -->
                <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,15,0,0">
                    <Button Content="+ Новый лист" Command="{Binding AddWaybillCommand}" Style="{StaticResource PrimaryButton}" Height="30"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Удалить" Command="{Binding DeleteWaybillCommand}" CommandParameter="{Binding SelectedWaybill}"
                                Style="{StaticResource ModernButton}" Foreground="#DC2626" BorderBrush="#FECACA" Background="#FEF2F2"
                                Visibility="{Binding CanDeleteWaybill, Converter={StaticResource BoolToVis}}" Height="30"/>
                        
                        <Button Grid.Column="2" Content="Архив" Command="{Binding ArchiveWaybillCommand}" 
                                Style="{StaticResource ModernButton}"
                                IsEnabled="{Binding CanArchive}" Height="30"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- === ПРАВАЯ КОЛОНКА (ДЕТАЛИ) === -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Gray" Opacity="0.001"/>
            </Border.Effect>

            <!-- КОНТЕНТ (ВИДЕН ЕСЛИ ВЫБРАНО) -->
            <Grid Visibility="{Binding IsDetailPanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Хедер -->
                    <RowDefinition Height="*"/>    <!-- Контент -->
                    <RowDefinition Height="Auto"/> <!-- Футер (Кнопки действий) -->
                </Grid.RowDefinitions>

                <!-- 1. ХЕДЕР: ИНФО О ЛИСТЕ -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    
                    
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="ПЛ №" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="{Binding SelectedWaybill.Id}" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="5,0,0,0"/>
                            <TextBlock Text="{Binding SelectedWaybill.AtCreated, StringFormat='от {0:dd MMMM yyyy}'}" FontSize="14" Foreground="Gray" VerticalAlignment="Bottom" Margin="10,0,0,4"/>
                        </StackPanel>
                        
                        <!-- Карточка Водителя и Машины -->
                        <Border Background="#F3F4F6" CornerRadius="6" Padding="10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <TextBlock Text="ВОДИТЕЛЬ" FontSize="10" FontWeight="Bold" Foreground="#6B7280"/>
                                    <TextBlock Text="{Binding SelectedWaybill.Driver.FullName}" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Rectangle Grid.Column="1" Width="1" Fill="#D1D5DB" Margin="15,2"/>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="АВТОМОБИЛЬ" FontSize="10" FontWeight="Bold" Foreground="#6B7280"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedWaybill.Car.Model}" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding SelectedWaybill.Car.FuelRate, StringFormat='({0} л/100км)'}" FontSize="12" Foreground="Gray" Margin="5,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 2. ТАБЛИЦЫ -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- А) МАРШРУТНЫЙ ЛИСТ (ЗАДАНИЯ) -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Border Background="#E0F2FE" CornerRadius="4" Padding="10,5" Margin="0,0,0,5">
                            <DockPanel>
                                <TextBlock Text="📋 ЗАДАНИЯ" FontSize="12" FontWeight="Bold" Foreground="#0369A1" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Добавить задание" Command="{Binding AddTaskCommand}" Style="{StaticResource ModernButton}" Padding="10,2" FontSize="11" Height="24" Width="150"/>
                                    <Button Content="Удалить" Command="{Binding DeleteTaskCommand}" CommandParameter="{Binding SelectedWaybillDetails}" Width="100" Style="{StaticResource ModernButton}" Padding="5,0" Margin="5,0,0,0" Height="24" Foreground="Red"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding SelectedWaybill.WaybillTasks}" 
                                  SelectedItem="{Binding SelectedTask}"
                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  BorderBrush="#E5E7EB" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM}" Width="60"/>
                                <DataGridTextColumn Header="Откуда" Binding="{Binding DeparturePoint}" Width="*"/>
                                <DataGridTextColumn Header="Куда" Binding="{Binding ArrivalPoint}" Width="*"/>
                                <DataGridTextColumn Header="Заказчик" Binding="{Binding CustomerName}" Width="150"/>
                                <DataGridTextColumn Header="Инфо" Binding="{Binding OtherInfo}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- СПЛИТТЕР -->
                    <GridSplitter Grid.Row="1" Height="3" HorizontalAlignment="Stretch" Background="#E5E7EB" Margin="0,15"/>

                    <!-- Б) ДЕТАЛИЗАЦИЯ (ТОПЛИВО) -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#F3F4F6" CornerRadius="4" Padding="10,5" Margin="0,0,0,5">
                            <DockPanel>
                                <TextBlock Text="⛽ УЧЕТ ТОПЛИВА И ПРОБЕГА" FontSize="12" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1" 
                                  ItemsSource="{Binding SelectedWaybill.WaybillDetails}" 
                                  SelectedItem="{Binding SelectedWaybillDetails}"
                                  AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single"
                                  BorderBrush="#E5E7EB" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Выезд" Binding="{Binding DepartureDateTime, StringFormat='dd.MM HH:mm'}"/>
                                <DataGridTextColumn Header="Возврат" Binding="{Binding ArrivalDateTime, StringFormat='dd.MM HH:mm'}"/>
                                <DataGridTextColumn Header="Км" Binding="{Binding Distance, StringFormat=F1}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Факт (л)" Binding="{Binding FuelConsumed, StringFormat=F1}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Норма (л)" Binding="{Binding NormalFuelConsumed, StringFormat=F1}" Foreground="Gray"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>

                <!-- 3. ФУТЕР: КНОПКИ ДЕЙСТВИЙ -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="ВЫДАТЬ ВОДИТЕЛЮ" 
                            Command="{Binding IssueWaybillCommand}"
                            Style="{StaticResource PrimaryButton}" Background="#059669" 
                            Visibility="{Binding CanIssue, Converter={StaticResource BoolToVis}}"
                            Height="30" Width="150"/>

                    <Button Content="✓ ОТКЛОНИТЬ РЕЙС" 
                            Command="{Binding DeclineWaybillCommand}"
                            Style="{StaticResource PrimaryButton}" Background="#AF2D2E"
                            Visibility="{Binding CanComplete, Converter={StaticResource BoolToVis}}"
                            Height="30" Width="150" Margin="10,0, 0, 0"/>
                    
                    <Button Content="✓ ЗАВЕРШИТЬ РЕЙС" 
                            Command="{Binding CompleteWaybillCommand}"
                            Style="{StaticResource PrimaryButton}" Background="#1E40AF"
                            Visibility="{Binding CanComplete, Converter={StaticResource BoolToVis}}"
                            Height="30" Width="150" Margin="10, 0"/>
                </StackPanel>
            </Grid>

            
            <!-- ЗАГЛУШКА (ЕСЛИ НЕ ВЫБРАНО) -->
            
        </Border>
        
        <Button Grid.Column="2" Content="Выйти" Command="{Binding LogOutCommand}" CommandParameter="{Binding SelectedWaybill}"
                Style="{StaticResource ModernButton}" 
                Width="100" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.4"/>
            </Button.Effect>
        </Button>
        
        <Grid Grid.Column="2" Visibility="{Binding IsDetailPanelVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⬅ Выберите документ" FontSize="18" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                <TextBlock Text="Выберите путевой лист из списка слева для просмотра" FontSize="14" Foreground="#D1D5DB" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>