<Window x:Class="WaybillWpf.Views.DriverManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:WaybillWpf.Converters" 
             xmlns:viewmodels="clr-namespace:WaybillWpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:DriverManagementViewModel}"
        
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#F3F4F6"> <!-- Светло-серый фон всего окна -->

    <Window.Resources>
        <conv:CustomBooleanToVisibilityConverter x:Key="VisConverter"/>

        <!-- СТИЛЬ ДЛЯ КНОПОК -->
        <Style TargetType="Button" x:Key="ModernButtonStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ ОСНОВНОЙ КНОПКИ (Акцент) -->
        <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Background" Value="#10B981"/> <!-- Зеленый -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ DATAGRID -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E5E7EB"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="35"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E0F2FE"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/> <!-- Список -->
            <ColumnDefinition Width="15"/>  <!-- Отступ -->
            <ColumnDefinition Width="*"/>   <!-- Детали -->
        </Grid.ColumnDefinitions>

        <!-- === ЛЕВАЯ КОЛОНКА: СПИСОК === -->
        <Border Grid.Column="0" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.1"/>
            </Border.Effect>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Мои рейсы" FontSize="20" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Список путевых листов" FontSize="12" Foreground="#6B7280"/>
                </StackPanel>

                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding WaybillsList}" 
                          SelectedItem="{Binding SelectedWaybill}"
                          SelectionMode="Single"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="40"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding AtCreated, StringFormat=dd.MM.yyyy}" Width="80"/>
                        <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.Model}" Width="*"/>
                        
                        <!-- КОЛОНКА СТАТУСА С "ПЛАШКОЙ" -->
                        <DataGridTemplateColumn Header="Статус" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E5E7EB"/> <!-- Default gray -->
                                                <Style.Triggers>
                                                    <!-- Выдан (Issued) / В работе -->
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Issued">
                                                        <Setter Property="Background" Value="#DBEAFE"/> <!-- Light Blue -->
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="InProgress">
                                                        <Setter Property="Background" Value="#FEF3C7"/> <!-- Light Yellow -->
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding WaybillStatus}" Value="Completed">
                                                        <Setter Property="Background" Value="#D1FAE5"/> <!-- Light Green -->
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Bold" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding WaybillStatus}"/>
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Issued">
                                                            <Setter Property="Text" Value="Назначен"/>
                                                            <Setter Property="Foreground" Value="#1E40AF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="InProgress">
                                                            <Setter Property="Text" Value="В пути"/>
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WaybillStatus}" Value="Completed">
                                                            <Setter Property="Text" Value="Сдан"/>
                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        
        
        
        <!-- === ПРАВАЯ КОЛОНКА: РАБОЧАЯ ОБЛАСТЬ === -->
        <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="20">
            <!-- Если лист выбран -->
            <Grid Visibility="{Binding IsDetailPanelVisible, Converter={StaticResource VisConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Хедер -->
                    <RowDefinition Height="*"/>    <!-- Задания -->
                    <RowDefinition Height="Auto"/> <!-- Разделитель -->
                    <RowDefinition Height="*"/>    <!-- Детали -->
                </Grid.RowDefinitions>

                <!-- 1. ЗАГОЛОВОК И ДЕЙСТВИЯ -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Путевой лист №" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="{Binding SelectedWaybill.Id}" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="5,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedWaybill.Car.Model}" FontSize="14" Foreground="#6B7280" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Кнопка СДАТЬ (видна если можно сдать) -->
                    <Button Grid.Column="1" Content="✓ Завершить и сдать" 
                            Command="{Binding AcceptingWaybillCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Visibility="{Binding CanAccepting, Converter={StaticResource VisConverter}}"/>
                </Grid>

                <!-- 2. ЗАДАНИЯ (ПЛАН) -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Background="#F3F4F6" CornerRadius="4" Padding="10,5" Margin="0,0,0,5">
                        <TextBlock Text="📋 ЗАДАНИЕ НА ПОЕЗДКУ (МАРШРУТ)" FontSize="12" FontWeight="Bold" Foreground="#4B5563"/>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedWaybill.WaybillTasks}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              BorderThickness="1" BorderBrush="#E5E7EB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM}" Width="60"/>
                            <DataGridTextColumn Header="Откуда" Binding="{Binding DeparturePoint}" Width="*"/>
                            <DataGridTextColumn Header="Куда" Binding="{Binding ArrivalPoint}" Width="*"/>
                            <DataGridTextColumn Header="Заказчик" Binding="{Binding CustomerName}" Width="150"/>
                            <DataGridTextColumn Header="Инфо" Binding="{Binding OtherInfo}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- РАЗДЕЛИТЕЛЬ -->
                <GridSplitter Grid.Row="2" Height="2" HorizontalAlignment="Stretch" Background="#E5E7EB" Margin="0,15"/>

                <!-- 3. ДЕТАЛИ (ФАКТ) -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#F3F4F6" CornerRadius="4" Padding="10,5" Margin="0,0,0,10">
                        <TextBlock Text="⛽ ОТЧЕТ ВОДИТЕЛЯ (ЗАМЕРЫ)" FontSize="12" FontWeight="Bold" Foreground="#4B5563"/>
                    </Border>

                    <!-- Панель управления деталями -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10"
                                Visibility="{Binding CanEditDetails, Converter={StaticResource VisConverter}}">
                        <Button Content="+ Добавить запись" Command="{Binding AddNewDetailCommand}" Style="{StaticResource ModernButtonStyle}" Width="200" Background="#EFF6FF" BorderBrush="#BFDBFE" TextElement.Foreground="#1D4ED8"/>
                        <Button Content="Изменить" Command="{Binding EditDetailCommand}" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0" Width="100"/>
                        <Button Content="Удалить" Command="{Binding DeleteWaybillDetailCommand}" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0" Width="100" Foreground="#DC2626" BorderBrush="#FECACA" Background="#FEF2F2"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" 
                              ItemsSource="{Binding SelectedWaybill.WaybillDetails}" 
                              SelectedItem="{Binding SelectedWaybillDetails}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              SelectionMode="Single"
                              BorderThickness="1" BorderBrush="#E5E7EB">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Выезд" Binding="{Binding DepartureDateTime, StringFormat='dd.MM HH:mm'}"/>
                            <DataGridTextColumn Header="Прибытие" Binding="{Binding ArrivalDateTime, StringFormat='dd.MM HH:mm'}"/>
                            <DataGridTextColumn Header="Пробег (км)" Binding="{Binding Distance, StringFormat=F1}" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Расход (л)" Binding="{Binding FuelConsumed, StringFormat=F1}"/>
                            <DataGridTextColumn Header="Норма (л)" Binding="{Binding NormalFuelConsumed, StringFormat=F1}" Foreground="Gray"/>
                            <DataGridTextColumn Header="Время (ч)" Binding="{Binding InWayTime, StringFormat='hh\\:mm'}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            
        </Border>
        
        <Grid Grid.Column="2" Visibility="{Binding IsDetailPanelVisible, Converter={StaticResource VisConverter}, ConverterParameter=Inverted}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⬅ Выберите путевой лист" FontSize="18" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                <TextBlock Text="Список доступных рейсов находится слева" FontSize="14" Foreground="#D1D5DB" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        <!-- Заглушка, если ничего не выбрано -->
        
        <Button Grid.Column="0" Content="Выйти" Command="{Binding LogOutCommand}" CommandParameter="{Binding SelectedWaybill}"
                Style="{StaticResource PrimaryButtonStyle}" Background="PaleVioletRed"
                Width="100" Height="30" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10">
            <Button.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.4"/>
            </Button.Effect>
        </Button>

    </Grid>
</Window>